set shell := ["bash", "-cu"]

# Import shared library
import '../../.just/lib.just'

binary := "/tmp/kohan-server"
port := "9091"
kohan_dir := justfile_directory()
pics_dir := "/tmp/pics"

[doc('Show available Kohan recipes')]
default:
    just --list

# Build Kohan binary.
[doc('Build the Kohan binary and UI assets')]
[group('build')]
build: _templ _css _format _js
    go build -o {{binary}} {{kohan_dir}}
    just _title "BUILD" "Kohan Ready"

# Run Kohan server with Air hot reload.
[doc('Run Kohan with Air hot reload')]
[group('run')]
air: kill-server
	mkdir -p {{pics_dir}}
	KOHAN_BINARY="{{binary}} auto serve {{pics_dir}} -p {{port}}" just _air-run {{kohan_dir}} {{port}}

[doc('Kill Kohan server on the configured port')]
[group('run')]
kill-server:
	lsof -ti:{{port}} | xargs kill -9 2>/dev/null || true

[doc('Reset Barkat DB files and restart Air')]
[group('run')]
reset-db:
	rm -f "$HOME/Downloads/barkat.db" "$HOME/Downloads/barkat.db-wal" "$HOME/Downloads/barkat.db-shm"
	just air
