package components

import "github.com/a-h/templ"

type SectionHeaderProps struct {
	Title       string
	Description string
	Class       string
	Attributes  templ.Attributes
}

templ SectionHeader(props SectionHeaderProps) {
	<div class={ "space-y-1 " + props.Class } { props.Attributes... }>
		<h3 class="text-lg font-semibold tracking-tight text-foreground">{ props.Title }</h3>
		if props.Description != "" {
			<p class="text-sm text-muted-foreground">{ props.Description }</p>
		}
	</div>
}
