package detail

import (
	"github.com/amanhigh/go-fun/components/kohan/ui/components"
	"github.com/amanhigh/go-fun/common/ui/widgets"
	"github.com/templui/templui/components/button"
)

// ============================================================
// STATE FLOW
// ============================================================

templ JournalDetailStateSection() {
	@components.StateBox(components.StateBoxProps{Variant: components.StateBoxLoading, ShowExpr: "current.loading"}) {
		<div class="flex items-center justify-center gap-2">
			@widgets.Spinner(widgets.SpinnerProps{Size: widgets.SpinnerSizeSm, Class: "text-sky-700"})
			<span>Loading journal details...</span>
		</div>
	}
	@components.StateBox(components.StateBoxProps{Variant: components.StateBoxError, ShowExpr: "current.hasError()"}) {
		<div class="space-y-3">
			<div class="font-medium" x-text="current.errorMessage"></div>
			@button.Button(button.Props{
				Variant:    button.VariantOutline,
				Type:       button.TypeButton,
				Attributes: templ.Attributes{"x-on:click": "current.loadJournal()"},
			}) {
				Retry
			}
		</div>
	}
	@components.StateBox(components.StateBoxProps{Variant: components.StateBoxEmpty, ShowExpr: "!current.loading && !current.hasError() && !current.journal"}) {
		No journal details available.
	}
}

templ JournalDetailEmptyState(message string, showExpr string) {
	@components.EmptyState(components.EmptyStateProps{Message: message, ShowExpr: showExpr, Class: "mt-5"})
}
