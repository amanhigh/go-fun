set shell := ["bash", "-cu"]

import '../../../.just/lib.just'

chart_version := trim(shell("grep '^version:' Chart.yaml | sed 's/^version: //'"))
release_version := if env('VERSION', '') != '' {
  env('VERSION')
} else if env('VER', '') != '' {
  env('VER')
} else {
  chart_version
}

[doc('Show available chart recipes')]
default:
    just --list

[group('setup')]
[doc('Add the Bitnami Helm repository')]
add:
    just _title "HELM" "Adding Bitnami Repository"
    just _run "helm repo add bitnami https://charts.bitnami.com/bitnami"

[group('setup')]
[doc('Install the Fun App Helm chart locally')]
setup-fun:
    just _title "HELM" "Installing Fun App Helm Chart"
    just _run "helm install fun-app . --set rateLimit.perMin=150"

[group('setup')]
[doc('Start the Vegeta helper pod for load testing')]
setup-vegeta:
    just _title "HELM" "Running Vegeta Attack"
    just _run "kubectl run vegeta --image='peterevans/vegeta' -- sh -c 'sleep 10000'"

[group('ops')]
[doc('Stream app logs into GoAccess analysis')]
setup-analyse:
    just _title "Analyse" "Log: GoAccess"
    kubectl -n fun-app logs $(kubectl get pods -n fun-app -o name | grep app | head -1) --since=1m -f | goaccess --log-format='%^ %d - %t | %s | %~%D | %b | %~%h | %^ | %m %U' --date-format='%Y/%m/%d' --time-format '%H:%M:%S'

[group('build')]
[doc('Update chart dependencies')]
update:
    just _title "HELM" "Updating Helm Dependencies"
    just _run "helm dependency update"
    just _run "helm dependency build"

[group('build')]
[doc('Package the Helm chart with the selected version')]
package: update
    #!/usr/bin/env bash
    set -euo pipefail
    version='{{release_version}}'
    just _title "HELM" "Packaging Fun App (${version}) Helm Chart"
    sed -i.bak -e "s/^version:.*/version: ${version}/" Chart.yaml
    rm -f Chart.yaml.bak
    just _run "helm package . -d ."

[group('info')]
[doc('Show Fun App Helm usage notes')]
info-fun:
    just _info "INFO" "Fun App Info"
    just _detail "INFO" "minikube tunnel"
    just _detail "INFO" "kubectl get svc app"
    just _detail "INFO" "http://<external_ip>:9001/metrics"
    just _detail "INFO" "http://app.docker/app/metrics"

[group('info')]
[doc('Show Helm release notes for the Fun App chart')]
info-fun-notes:
    just _info "INFO" "Fun App Notes"
    helm get notes fun-app

[group('info')]
[doc('Show Vegeta usage notes for Helm and Devspace flows')]
info-vegeta:
    just _info "INFO" "Vegeta Info"
    just _detail "INFO" "Login Vegeta Pod"
    just _detail "HELM" "echo 'GET http://fun-app:9090/v1/person/all' | vegeta attack | vegeta report"
    just _detail "DEVSPACE" "echo 'GET http://app:8080/v1/person/all' | vegeta attack | vegeta report"
    just _detail "LOAD" "Portforward 8080: http://localhost:8080/metrics and fun-app/it Make"
    just _detail "PROMETHEUS" "http://prometheus.docker/graph?g0.expr=funapp_create_person&g0.tab=0&g0.display_mode=stacked&g0.show_exemplars=0&g0.range_input=15m"

[group('info')]
[doc('Show Istio and Grafana references for the chart')]
info-istio:
    just _info "INFO" "Istio Info"
    just _detail "INFO" "Grafana Import: /fun-app/it/dashboard.json"
    just _detail "INFO" "Prometheus: : http://localhost:9090/graph?g0.expr=rate(fun_app_person_count%5B5m%5D)&g0.tab=0&g0.stacked=0&g0.show_exemplars=0&g0.range_input=5m&g1.expr=fun_app_person_create_time_bucket&g1.tab=0&g1.stacked=1&g1.show_exemplars=1&g1.range_input=1h&g2.expr=rate(fun_app_person_create_time_count%5B5m%5D)&g2.tab=0&g2.stacked=0&g2.show_exemplars=0&g2.range_input=1h"

[group('clean')]
[doc('Delete the installed Fun App Helm release')]
clean-fun:
    just _warn "HELM" "Deleting Fun App Helm Chart"
    -just _run "helm delete fun-app"

[group('clean')]
[doc('Delete the Vegeta helper pod')]
clean-vegeta:
    just _warn "HELM" "Deleting Vegeta Attack"
    -just _run "kubectl delete pod vegeta"

[group('clean')]
[doc('Delete packaged chart archives')]
clean-package:
    just _warn "HELM" "Deleting Helm Package(s)"
    just _run "rm -f ./*.tgz"

[group('info')]
[doc('Show Fun App and Vegeta information')]
info: info-fun info-vegeta

[group('info')]
[doc('Show extended chart information including Istio and notes')]
infos: info info-istio info-fun-notes

[group('setup')]
[doc('Run one-time Helm repository setup')]
prepare: add

[group('setup')]
[doc('Install the chart and the Vegeta helper pod')]
setup: setup-fun setup-vegeta

[group('clean')]
[doc('Clean chart resources and generated archives')]
clean: clean-fun clean-package clean-vegeta

[group('ops')]
[doc('Analyse Fun App logs through GoAccess')]
analyse: setup-analyse

[group('setup')]
[doc('Clean, install, and show chart information')]
reset: clean setup info

[group('setup')]
[doc('Run the full chart workflow including packaging and cleanup')]
all: prepare reset package clean
