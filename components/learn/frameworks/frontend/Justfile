set shell := ["bash", "-cu"]

# Import shared library
import '../../../../.just/lib.just'

binary := "/tmp/ui-demo"
frontend_dir := justfile_directory()
frontend_port := "9090"

[doc('Show available frontend demo recipes')]
default:
    just --list

# Build Frontend Demo binary.
[doc('Build the frontend demo binary and UI assets')]
[group('build')]
build: _templ _css _format _js
    go build -o {{binary}} {{frontend_dir}}/demo
    just _title "BUILD" "Frontend Demo Ready"

# Run frontend demo server with Air hot reload.
[doc('Run the frontend demo with Air hot reload')]
[group('run')]
air:
    BINARY="{{binary}}" just _air-run {{frontend_dir}} {{frontend_port}}
